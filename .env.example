# Copy this file to `.env` and adjust if needed:  cp .env.example .env
# docker-compose reads these automatically.

# --- Redis ---
# Inside docker-compose, services reach Redis by the service name "redis".
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins for local dev (the Vite frontend).
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Workers ---
# Default queue names workers listen on, highest priority first.
QUEUE_NAMES=high,default,low
# Seconds before a running job is considered timed out.
JOB_TIMEOUT=180
# How many times a failed job is retried before going to the dead-letter (failed) registry.
JOB_MAX_RETRIES=3

# --- Demo task behaviour ---
# Probability (0.0-1.0) that the mocked email task fails, so retries are observable.
EMAIL_FAILURE_RATE=0.5
